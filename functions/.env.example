# Swiftech API (get from Swiftech dashboard)
SWIFTECH_BASE_URL=https://api.swiftech.com
SWIFTECH_API_KEY=your_api_key
SWIFTECH_SECRET=your_secret

# Optional: webhook secret to verify Swiftech callbacks
SWIFTECH_WEBHOOK_SECRET=your_webhook_secret

# Payment methods: 32-byte key (base64) for double encryption of card/bank data in Firestore.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAYMENT_ENCRYPTION_KEY=your_base64_32_byte_key

# Optional: if Swiftech supports a vault, set this to save payment methods with them (e.g. https://api.swiftech.com/v1/payment-methods)
# SWIFTECH_VAULT_URL=
# SWIFTECH_PAYMENT_METHODS_URL=
